{
  "name": "tvchub-functions",
  "description": "Cloud Functions for TVCHub: Gmail referral ingestion",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0",
    "html-to-text": "^9.0.5"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "typescript": "^5.6.0"
  },
  "private": true
}
