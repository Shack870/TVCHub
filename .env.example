# Firebase web app config — copy to .env.local and fill in from
# Firebase Console -> Project settings -> Your apps -> Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI (LLM-based PDF extraction experiment). Script/server side only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# On-demand "Check for new leads" button. Deploy apps-script/Code.gs as a
# Web App and paste its /exec URL + the CHECK_TOKEN script property here.
VITE_INBOX_CHECK_URL=
VITE_INBOX_CHECK_TOKEN=
